function CORE_placeDept_(slot, dept, data) {
  data[slot.r][slot.c] = CORE_norm_(dept);
}

/***********************
 * QUOTA DONE
 ***********************/
function CORE_allQuotaDone_(remaining, deptList) {
  return deptList.every(d => Number(remaining[d] || 0) <= 0);
}

/***********************
 * DESIRE GETTER
 ***********************/
function CORE_getDesire_(rule, shiftKey, rowType) {
  if (!rule || !rule.avail) return 0;

  if (rowType === "WN_B4_WD" && shiftKey === "N") {
    return Number(rule.avail.weekend.N_before_WD || 0);
  }

  const isWeekend = (rowType !== "WEEKDAY");
  const side = isWeekend ? "weekend" : "weekday";
  return Number((rule.avail[side] && rule.avail[side][shiftKey]) || 0);
}

/***********************
 * ME potential
 ***********************/
function CORE_mePotential_(data, r, dept, colMap) {
  const d = CORE_norm_(dept);

  const mCols = colMap.shiftCols.M;
  const eCols = colMap.shiftCols.E;

  const mFilled = mCols.map(c => CORE_norm_(data[r][c])).filter(Boolean);
  const eFilled = eCols.map(c => CORE_norm_(data[r][c])).filter(Boolean);

  const mHas = mFilled.indexOf(d) >= 0;
  const eHas = eFilled.indexOf(d) >= 0;

  const mHasEmpty = (mFilled.length < mCols.length);
  const eHasEmpty = (eFilled.length < eCols.length);

  return (mHas && eHasEmpty) || (eHas && mHasEmpty) || (mHasEmpty && eHasEmpty);
}

/***********************
 * CONSECUTIVE CHECK
 ***********************/
function CORE_checkNoMoreThan2Consecutive_(timeline, data, idx, dept, assumePlaceIdx) {
  const d = CORE_norm_(dept);
  let run = 1;

  function hasDeptAt(tIndex) {
    const t = timeline[tIndex];
    const inShift = t.cols.map(c => CORE_norm_(data[t.r][c]));
    if (inShift.indexOf(d) >= 0) return true;
    return (tIndex === assumePlaceIdx);
  }

  for (let i = idx - 1; i >= 0; i--) {
    if (hasDeptAt(i)) run++;
    else break;
  }
  for (let i = idx + 1; i < timeline.length; i++) {
    if (hasDeptAt(i)) run++;
    else break;
  }

  if (run > 2) return { ok:false, reason:"ติดกันเกิน 2 เวร (run=" + run + ")" };
  return { ok:true, reason:"" };
}

/***********************
 * RULE READER
 ***********************/
function CORE_readRulesFromRuleSheet_(sh) {
  const v = sh.getDataRange().getValues();
  if (v.length < 2) throw new Error(sh.getName() + " ไม่มีข้อมูล");

  const headers = v[0].map(x => String(x || "").trim());

  const cDept = CORE_findCol_(headers, ["Department", "Dept", "แผนก"]);
  const cMustPair = CORE_findCol_(headers, ["Must_Pair"]);
  const cMustNot = CORE_findCol_(headers, ["Must_Not_Pair"]);

  const cWeekdayM = CORE_findCol_(headers, ["Weekday_M"]);
  const cWeekdayE = CORE_findCol_(headers, ["Weekday_E"]);
  const cWeekdayN = CORE_findCol_(headers, ["Weekday_N"]);

  const cWeekendM = CORE_findCol_(headers, ["Weekend_M"]);
  const cWeekendE = CORE_findCol_(headers, ["Weekend_E"]);
  const cWeekendN = CORE_findCol_(headers, ["Weekend_N"]);
  const cWeekendNBefore = CORE_findCol_(headers, ["Weekend_N_before_WD"]);

  const cWeekdayME = CORE_findCol_(headers, ["Weekday_ME"]);
  const cWeekendME = CORE_findCol_(headers, ["Weekend_ME"]);

  const cIdeal = CORE_findCol_(headers, ["Ideal_shift"]);
  const cFix   = CORE_findCol_(headers, ["Fix_shift"]);
  const cPrio  = CORE_findCol_(headers, ["Priority"]);

  const mustHave = [
    cDept,cMustPair,cMustNot,
    cWeekdayM,cWeekdayE,cWeekdayN,
    cWeekendM,cWeekendE,cWeekendN,cWeekendNBefore,
    cWeekdayME,cWeekendME,
    cIdeal
  ];
  if (mustHave.some(x => x === -1)) {
    throw new Error("หัวคอลัมน์ใน " + sh.getName() + " ไม่ครบ/ชื่อไม่ตรง (ต้องมี Department, Must_Pair, Must_Not_Pair, คอลัมน์วัน/กะ, Weekday_ME, Weekend_ME, Ideal_shift)");
  }

  const rules = {};
  for (let r = 1; r < v.length; r++) {
    const dept = CORE_norm_(v[r][cDept]);
    if (!dept) continue;

    rules[dept] = {
      dept,
      mustPair: CORE_splitList_(v[r][cMustPair]).map(CORE_norm_).filter(Boolean),
      mustNotPair: CORE_splitList_(v[r][cMustNot]).map(CORE_norm_).filter(Boolean),

      avail: {
        weekday: {
          M: Number(v[r][cWeekdayM] || 0),
          E: Number(v[r][cWeekdayE] || 0),
          N: Number(v[r][cWeekdayN] || 0)
        },
        weekend: {
          M: Number(v[r][cWeekendM] || 0),
          E: Number(v[r][cWeekendE] || 0),
          N: Number(v[r][cWeekendN] || 0),
          N_before_WD: Number(v[r][cWeekendNBefore] || 0)
        }
      },

      meWeekday: Number(v[r][cWeekdayME] || 0),
      meWeekend: Number(v[r][cWeekendME] || 0),

      ideal: Number(v[r][cIdeal] || 0),
      fixShift: (cFix >= 0) ? Number(v[r][cFix] || 0) : 0,
      priority: (cPrio >= 0) ? Number(v[r][cPrio] || 0) : 0
    };
  }

  return rules;
}

/***********************
 * CALENDAR MODE: BY_COLOR
 ***********************/
function CORE_detectWeekendColorFromColA_(colA_bg) {
  for (let r = 1; r < colA_bg.length; r++) {
    const c = CORE_normColor_(colA_bg[r][0]);
    if (c && c !== "#ffffff" && c !== "white") return c;
  }
  return "#f6c6a5";
}

function CORE_buildSlotTypeByColor_(colA_bg, weekendColor) {
  const type = [];
  for (let r = 0; r < colA_bg.length; r++) {
    const c = CORE_normColor_(colA_bg[r][0]);
    const isWk = (c && c !== "#ffffff" && c !== "white" && c === weekendColor);
    type[r] = isWk ? "WEEKEND" : "WEEKDAY";
  }
  for (let r = 0; r < type.length; r++) {
    const todayWk = (type[r] === "WEEKEND");
    const tomWk   = (r + 1 < type.length) ? (type[r + 1] === "WEEKEND") : false;
    if (todayWk && !tomWk) type[r] = "WN_B4_WD";
  }
  return type;
}

/***********************
 * CALENDAR MODE: BY_DATE
 ***********************/
function CORE_loadHolidaySet_(holidaySh) {
  const lastRow = holidaySh.getLastRow();
  if (lastRow < 1) return new Set();
  const vals = holidaySh.getRange(1,1,lastRow,1).getValues();
  const set = new Set();
  for (let i = 0; i < vals.length; i++) {
    const v = vals[i][0];
    if (v instanceof Date) set.add(CORE_toISODateKey_(v));
  }
  return set;
}

function CORE_buildSlotTypeByDate_(data, monthCell, holidaySet, dayCol) {
  const year = monthCell.getFullYear();
  const month = monthCell.getMonth();

  function isWeekend_(dt) {
    const d = dt.getDay();
    return d === 0 || d === 6;
  }

  const type = [];
  for (let r = 0; r < data.length; r++) {
    if (r === 0) { type[r] = "WEEKDAY"; continue; }
    const dayNum = Number(data[r][dayCol] || 0);
    if (!dayNum) { type[r] = "WEEKDAY"; continue; }

    const dt = new Date(year, month, dayNum);
    const key = CORE_toISODateKey_(dt);
    const isWk = isWeekend_(dt) || holidaySet.has(key);
    type[r] = isWk ? "WEEKEND" : "WEEKDAY";
  }

  for (let r = 1; r < data.length; r++) {
    const dayNum = Number(data[r][dayCol] || 0);
    if (!dayNum) continue;

    const dt = new Date(year, month, dayNum);
    const key = CORE_toISODateKey_(dt);
    const todayWk = (isWeekend_(dt) || holidaySet.has(key));

    const next = new Date(year, month, dayNum + 1);
    const nextKey = CORE_toISODateKey_(next);
    const tomWk = (isWeekend_(next) || holidaySet.has(nextKey));

    if (todayWk && !tomWk) type[r] = "WN_B4_WD";
  }

  return type;
}

/***********************
 * LOG WRITER
 ***********************/
function CORE_writeLog_(ss, sheetName, rows) {
  let sh = ss.getSheetByName(sheetName);
  if (!sh) sh = ss.insertSheet(sheetName);
  sh.clear();
  if (!rows || !rows.length) return;
  sh.getRange(1, 1, rows.length, rows[0].length).setValues(rows);
  sh.autoResizeColumns(1, rows[0].length);
}

/***********************
 * RESULT HEADER MAP
 ***********************/
function CORE_normHeader_(v) {
  return String(v || "")
    .trim()
    .toUpperCase()
    .replace(/\s+/g, "")
    .replace(/_/g, "");
}

function CORE_findColByNames_(headers, names) {
  const H = headers.map(CORE_normHeader_);
  const targets = (names || []).map(CORE_normHeader_);
  for (let i = 0; i < H.length; i++) {
    for (const t of targets) {
      if (H[i] === t) return i;
    }
  }
  return -1;
}

function CORE_getResultColMap_Flex_(headerRow) {
  const headers = (headerRow || []).map(x => String(x || "").trim());

  const cDay = CORE_findColByNames_(headers, ["DAY", "วัน", "DATE"]);
  if (cDay < 0) {
    throw new Error("Result ต้องมีคอลัมน์ DAY หรือ วัน");
  }

  const shiftCols = { M: [], E: [], N: [] };

  for (let i = 0; i < headers.length; i++) {
    const h = headers[i].toUpperCase().replace(/\s+/g, "");
    if (/^M\d+$/.test(h)) shiftCols.M.push(i);
    if (/^E\d+$/.test(h)) shiftCols.E.push(i);
    if (/^N\d+$/.test(h)) shiftCols.N.push(i);
  }

  if (!shiftCols.M.length || !shiftCols.E.length || !shiftCols.N.length) {
    throw new Error("Result ต้องมีอย่างน้อย M1, E1, N1 (สามารถเพิ่ม M2,M3,... ได้อิสระ)");
  }

  const maxColIndex = Math.max(
    cDay,
    ...shiftCols.M,
    ...shiftCols.E,
    ...shiftCols.N
  );

  return { dayCol: cDay, shiftCols, maxColIndex };
}

/***********************
 * GET DEPT LIST
 ***********************/
function CORE_getDeptList_FromRuleSheet_(sh) {
  const v = sh.getDataRange().getValues();
  if (v.length < 2) return [];
  const headers = v[0].map(x => String(x || "").trim());
  const cDept = CORE_findCol_(headers, ["Department", "Dept", "แผนก"]);
  const deptCol = (cDept >= 0) ? cDept : 0;

  const set = new Set();
  for (let r = 1; r < v.length; r++) {
    const d = CORE_norm_(v[r][deptCol]);
    if (d) set.add(d);
  }
  return Array.from(set).sort();
}

/***********************
 * BASIC UTILS
 ***********************/
function CORE_now_() {
  return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd HH:mm:ss");
}

function CORE_cellA1_(r0, c0) {
  return CORE_toA1_(r0 + 1, c0 + 1);
}

function CORE_toA1_(row, col) {
  let s = "";
  let n = col;
  while (n > 0) {
    const m = (n - 1) % 26;
    s = String.fromCharCode(65 + m) + s;
    n = Math.floor((n - 1) / 26);
  }
  return s + row;
}

function CORE_findCol_(headers, keys) {
  const lower = headers.map(h => String(h || "").toLowerCase());
  for (let i = 0; i < lower.length; i++) {
    for (const k of keys) {
      const kk = String(k).toLowerCase();
      if (lower[i] === kk) return i;
      if (lower[i].indexOf(kk) >= 0) return i;
    }
  }
  return -1;
}

function CORE_splitList_(v) {
  const s = String(v || "").trim();
  if (!s) return [];
  return s.split(/[\s,]+/).map(x => String(x || "").trim()).filter(Boolean);
}

function CORE_norm_(v) {
  return String(v || "").trim().toUpperCase();
}

function CORE_normColor_(c) {
  if (!c) return "";
  return String(c).trim().toLowerCase();
}

function CORE_toISODateKey_(date) {
  return date.getFullYear() + "-" + CORE_pad2_(date.getMonth() + 1) + "-" + CORE_pad2_(date.getDate());
}

function CORE_pad2_(n) {
  n = String(n);
  return n.length === 1 ? ("0" + n) : n;
}

/***********************
 * คอลัมน์ A เป็น text หรือไม่
 ***********************/
function CORE_isTextInColA_(v) {
  if (v == null) return false;
  if (v instanceof Date) return false;

  const s = String(v).trim();
  if (!s) return false;

  return !/^\d+$/.test(s);
}
