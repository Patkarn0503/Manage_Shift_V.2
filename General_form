/************************************************************
 * MAIN: RUN SCHEDULER (MRV_SLOT_FIRST, STOP WHEN QUOTA DONE)
 * config:
 * - ruleSheetName:  string
 * - resultSheetName:string
 * - calendarMode: "BY_COLOR" | "BY_DATE"
 * - scoringPolicy:"DESIRE" | "DESIRE_ME" | "DESIRE_ME_QUOTA" | "DESIRE_ME_QUOTA_PRIORITY"
 * - deptList:     array of departments
 * - autoPair:     boolean
 ************************************************************/
function CORE_runScheduler_(config) {
  const ss = SpreadsheetApp.getActive();

  const ruleSheetName   = String((config && config.ruleSheetName) || "").trim();
  const resultSheetName = String((config && config.resultSheetName) || "").trim();
  if (!ruleSheetName)   return { ok:false, message:"ไม่ได้ระบุชื่อชีทกติกา (Rule Sheet)" };
  if (!resultSheetName) return { ok:false, message:"ไม่ได้ระบุชื่อชีทผลลัพธ์ (Result Sheet)" };

  const calendarMode  = String((config && config.calendarMode) || "BY_COLOR").toUpperCase();
  const scoringPolicy = String((config && config.scoringPolicy) || "DESIRE_ME_QUOTA_PRIORITY").toUpperCase();
  const autoPair      = !!(config && config.autoPair);

  let deptList = (config && config.deptList) ? config.deptList : [];
  deptList = deptList.map(CORE_norm_).filter(Boolean);

  if (!deptList.length) {
    return { ok:false, message:"ไม่ได้เลือกแผนก/รายชื่อ (deptList ว่าง)" };
  }

  const ruleSh   = ss.getSheetByName(ruleSheetName);
  const resultSh = ss.getSheetByName(resultSheetName);
  const holSh    = ss.getSheetByName(CORE_SHEET_HOLIDAY);

  if (!ruleSh)   throw new Error('ไม่พบชีท "' + ruleSheetName + '"');
  if (!resultSh) throw new Error('ไม่พบชีท "' + resultSheetName + '"');

  const rules = CORE_readRulesFromRuleSheet_(ruleSh);

  deptList.forEach(d => {
    if (!rules[d]) throw new Error('ไม่พบกติกาของ "' + d + '" ในชีท ' + ruleSheetName);
  });

  /**************
   * Load Result
   **************/
  const lastRow = Math.max(1, resultSh.getLastRow());
  const lastCol = Math.max(1, resultSh.getLastColumn());
  if (lastRow < 2) return { ok:true, message:"Result ไม่มีข้อมูลให้จัด (ต้องมีแถววันอย่างน้อย 1 แถว)" };

  const headerRow = resultSh.getRange(1, 1, 1, lastCol).getValues()[0];
  const colMap = CORE_getResultColMap_Flex_(headerRow);

  const width = colMap.maxColIndex + 1;
  const range = resultSh.getRange(1, 1, lastRow, width);
  const data  = range.getValues();

  const colA_bg = resultSh.getRange(1, 1, lastRow, 1).getBackgrounds();

  if (data.length < 2) {
    return { ok:true, message:"Result ไม่มีข้อมูลให้จัด (ต้องมีแถววันอย่างน้อย 1 แถว)" };
  }

  /**************
   * Calendar / SlotType
   **************/
  let slotTypeByRow = [];
  if (calendarMode === "BY_DATE") {
    const monthCell = resultSh.getRange("J1").getValue();
    if (!(monthCell instanceof Date)) {
      throw new Error('calendarMode=BY_DATE ต้องให้ ' + resultSheetName + '!J1 เป็นวันที่ของเดือน (เช่น 2026-01-01)');
    }
    const holidaySet = holSh ? CORE_loadHolidaySet_(holSh) : new Set();
    slotTypeByRow = CORE_buildSlotTypeByDate_(data, monthCell, holidaySet, colMap.dayCol);
  } else {
    const weekendColor = CORE_detectWeekendColorFromColA_(colA_bg);
    slotTypeByRow = CORE_buildSlotTypeByColor_(colA_bg, weekendColor);
  }

  /**************
   * Build timeline
   **************/
  const timeline = [];
  const tIndexMap = {};

  for (let r = 1; r < data.length; r++) {
    if (CORE_isTextInColA_(data[r][0])) continue;

    const dayVal = data[r][colMap.dayCol];
    if (dayVal === "" || dayVal == null) continue;

    const day = dayVal;
    ["M","E","N"].forEach(sh => {
      const cols = colMap.shiftCols[sh];
      const t = { r, day, shift: sh, cols, rowType: slotTypeByRow[r] || "WEEKDAY" };
      const idx = timeline.length;
      timeline.push(t);
      tIndexMap[r + "|" + sh] = idx;
    });
  }

  if (!timeline.length) {
    return { ok:true, message:"ไม่พบแถววันใน Result (หรือถูกข้ามทั้งหมดเพราะคอลัมน์ A เป็นข้อความ)" };
  }

  /**************
   * used / remaining
   **************/
  const used = {};
  deptList.forEach(d => used[d] = 0);

  const slotCols = [].concat(colMap.shiftCols.M, colMap.shiftCols.E, colMap.shiftCols.N);
  for (let r = 1; r < data.length; r++) {
    if (CORE_isTextInColA_(data[r][0])) continue;

    for (const c of slotCols) {
      const d = CORE_norm_(data[r][c]);
      if (used[d] != null) used[d]++;
    }
  }

  const remaining = {};
  deptList.forEach(d => {
    const fix   = Number(rules[d].fixShift || 0);
    const ideal = Number(rules[d].ideal || 0);
    const q = fix > 0 ? fix : ideal;
    remaining[d] = Math.max(0, q - Number(used[d] || 0));
  });

  /**************
   * Config weights
   **************/
  const CFG = {
    W_DESIRE: 100,
    W_ME_BONUS: 60,
    W_QUOTA: 40,
    W_PRIORITY: 12
  };

  /**************
   * Log
   **************/
  const log = [];
  log.push(["ts","step","pass","day","shift","cell","dept","action","reason","score"]);

  /**************
   * Passes
   **************/
  const passes = [
    { name: "PASS1_WEEKDAY",      accept: (rowType) => rowType === "WEEKDAY" },
    { name: "PASS2_WEEKEND",      accept: (rowType) => rowType === "WEEKEND" },
    { name: "PASS3_WN_BEFORE_WD", accept: (rowType) => rowType === "WN_B4_WD" }
  ];

  let filledTotal = 0;

  const baseCtx = {
    data, timeline, tIndexMap, deptList, rules, remaining,
    scoringPolicy, CFG, autoPair, log, colMap
  };

  for (const p of passes) {
    const filled = CORE_runMRVPass_(p.name, p.accept, baseCtx);
    filledTotal += filled;
    if (CORE_allQuotaDone_(remaining, deptList)) break;
  }

  if (!CORE_allQuotaDone_(remaining, deptList)) {
    const filledX = CORE_runMRVPass_("FINAL_MRV_ANYTYPE", (_rowType) => true, baseCtx);
    filledTotal += filledX;
  }

  range.setValues(data);
  CORE_writeLog_(ss, CORE_SHEET_LOG, log);

  const remainLines = deptList.map(d => `${d}=${remaining[d]}`).join(", ");

  const msg =
    `โครงกลาง (MRV_SLOT_FIRST) เสร็จ\n` +
    `- ruleSheet=${ruleSheetName}, resultSheet=${resultSheetName}\n` +
    `- policy=${scoringPolicy}, calendarMode=${calendarMode}, autoPair=${autoPair}\n` +
    `- เติมเพิ่มทั้งหมด: ${filledTotal}\n` +
    `- โควต้าคงเหลือ: ${remainLines}\n` +
    (CORE_allQuotaDone_(remaining, deptList)
      ? `- สถานะ: โควต้าครบทุกแผนก`
      : `- สถานะ: ยังมีโควต้าค้าง (ดู Log เพื่อหาสาเหตุว่าช่องไหนไม่มี candidate)`);

  return { ok:true, message: msg };
}

/***********************
 * MRV PASS
 ***********************/
function CORE_runMRVPass_(passName, acceptTypeFn, ctx) {
  const {
    data, timeline, tIndexMap, deptList, rules, remaining,
    autoPair, log, colMap
  } = ctx;

  let filled = 0;
  let guard = 0;

  while (!CORE_allQuotaDone_(remaining, deptList)) {
    guard++;
    if (guard > 5000) {
      log.push([
        CORE_now_(),"CORE",passName,"","","","","STOP",
        "guard exceeded: ลูปเกิน 5000 รอบ จึงหยุดเพื่อป้องกันค้าง",""
      ]);
      break;
    }

    const emptySlots = CORE_collectEmptySlots_(timeline, acceptTypeFn, data, colMap);
    if (!emptySlots.length) break;

    let bestSlot = null;
    let bestCand = null;
    let bestCount = Infinity;
    let bestTopScore = -1;

    for (const s of emptySlots) {
      const cands = CORE_getCandidatesForSlot_(s, ctx);
      const cnt = cands.length;
      if (cnt <= 0) continue;

      const top = cands[0];
      if (cnt < bestCount || (cnt === bestCount && top.score > bestTopScore)) {
        bestCount = cnt;
        bestTopScore = top.score;
        bestSlot = s;
        bestCand = top;
      }
    }

    if (!bestSlot || !bestCand) break;

    CORE_placeDept_(bestSlot, bestCand.dept, data);
    if (remaining[bestCand.dept] > 0) remaining[bestCand.dept]--;

    filled++;
    log.push([
      CORE_now_(),"CORE",passName,bestSlot.day,bestSlot.shift,
      CORE_cellA1_(bestSlot.r, bestSlot.c),
      bestCand.dept,"FILL",bestCand.reason,String(bestCand.score)
    ]);

    if (autoPair) {
      const t = timeline[bestSlot.tIndex];
      const otherCol = CORE_pickEmptyPartnerCol_(t, bestSlot.c, data);
      const otherVal = (otherCol != null) ? CORE_norm_(data[t.r][otherCol]) : "";

      const rule = rules[CORE_norm_(bestCand.dept)];
      const mp = (rule && rule.mustPair) ? rule.mustPair : [];
      const hasEmpBan = !!(rule && rule.mustNotPair && rule.mustNotPair.indexOf("EMP") >= 0);

      const otherIsEmpty = (otherCol != null) && !otherVal;
      const mustBePairedNow = otherIsEmpty && (hasEmpBan || (mp && mp.length));

      if (mustBePairedNow) {
        const slot2 = CORE_makeSlot_(t.r, t.shift, otherCol, tIndexMap, data, colMap);
        const bestPartner = CORE_pickBestPartnerForSlot_(slot2, mp, ctx);

        if (bestPartner) {
          CORE_placeDept_(slot2, bestPartner.dept, data);
          if (remaining[bestPartner.dept] > 0) remaining[bestPartner.dept]--;
          filled++;
          log.push([
            CORE_now_(),"CORE",passName,slot2.day,slot2.shift,
            CORE_cellA1_(slot2.r, slot2.c),
            bestPartner.dept,"FILL","autopair " + bestPartner.reason,String(bestPartner.score)
          ]);
        } else {
          data[t.r][bestSlot.c] = "";
          remaining[bestCand.dept] = (remaining[bestCand.dept] || 0) + 1;
          filled--;
          log.push([
            CORE_now_(),"CORE",passName,bestSlot.day,bestSlot.shift,
            CORE_cellA1_(bestSlot.r, bestSlot.c),
            bestCand.dept,"NOFILL","atomic pair required but no partner available",""
          ]);
        }
      } else {
        if (otherIsEmpty && mp.length) {
          const slot2 = CORE_makeSlot_(t.r, t.shift, otherCol, tIndexMap, data, colMap);
          const bestPartner = CORE_pickBestPartnerForSlot_(slot2, mp, ctx);

          if (bestPartner) {
            CORE_placeDept_(slot2, bestPartner.dept, data);
            if (remaining[bestPartner.dept] > 0) remaining[bestPartner.dept]--;
            filled++;
            log.push([
              CORE_now_(),"CORE",passName,slot2.day,slot2.shift,
              CORE_cellA1_(slot2.r, slot2.c),
              bestPartner.dept,"FILL","autopair " + bestPartner.reason,String(bestPartner.score)
            ]);
          } else {
            log.push([
              CORE_now_(),"CORE",passName,bestSlot.day,bestSlot.shift,
              CORE_cellA1_(t.r, otherCol),
              bestCand.dept,"WARN","autoPair: หา partner ที่ผ่านเงื่อนไข/เหลือโควต้าไม่ได้",""
            ]);
          }
        }
      }
    }
  }

  return filled;
}

/***********************
 * CANDIDATES FOR SLOT
 ***********************/
function CORE_getCandidatesForSlot_(slot, ctx) {
  const { deptList, remaining } = ctx;

  const out = [];
  for (const dept of deptList) {
    if ((remaining[dept] || 0) <= 0) continue;

    const check = CORE_checkCandidate_(slot, dept, ctx);
    if (!check.ok) continue;

    const scoreObj = CORE_scoreCandidate_(slot, dept, ctx);
    out.push({ dept, score: scoreObj.score, reason: scoreObj.reason });
  }

  out.sort((a,b) => b.score - a.score);
  return out;
}

/***********************
 * HARD CHECK
 ***********************/
function CORE_checkCandidate_(slot, dept, ctx) {
  const { data, timeline, rules } = ctx;

  const d = CORE_norm_(dept);
  const t = timeline[slot.tIndex];

  const inThisShift = t.cols.map(c => CORE_norm_(data[t.r][c])).filter(Boolean);
  if (inThisShift.indexOf(d) >= 0) return { ok:false, reason:"duplicate dept in same shift" };

  const rule = rules[d];
  if (!rule) return { ok:false, reason:"missing rule" };

  const desire = CORE_getDesire_(rule, t.shift, t.rowType);
  if (desire <= 0) return { ok:false, reason:"desire=0" };

  const otherFilled = inThisShift;

  if (rule.mustNotPair && rule.mustNotPair.length) {
    const hasEmpBan = (rule.mustNotPair.indexOf("EMP") >= 0);

    if (hasEmpBan) {
      const wouldBeAlone = (otherFilled.length === 0);
      if (wouldBeAlone) {
        const okPartner = CORE_hasFeasiblePartnerForEmpMulti_(slot, d, ctx);
        if (!okPartner) return { ok:false, reason:"EMP: require feasible partner but none available" };
      }
    }

    for (const x of otherFilled) {
      if (rule.mustNotPair.indexOf(x) >= 0) return { ok:false, reason:"hit must_not_pair " + x };
    }
  }

  if (rule.mustPair && rule.mustPair.length) {
    if (otherFilled.length > 0) {
      for (const x of otherFilled) {
        if (rule.mustPair.indexOf(x) < 0) {
          return { ok:false, reason:"must_pair not satisfied (other=" + x + ")" };
        }
      }
    } else {
      const okPartner = CORE_hasFeasiblePartnerForEmpMulti_(slot, d, ctx);
      if (!okPartner) return { ok:false, reason:"must_pair requires partner but none feasible" };
    }
  }

  const cons = CORE_checkNoMoreThan2Consecutive_(timeline, data, slot.tIndex, d, slot.tIndex);
  if (!cons.ok) return { ok:false, reason: cons.reason };

  return { ok:true, reason:"ok" };
}

/***********************
 * SHALLOW CHECK
 * ใช้สำหรับเช็ก partner feasibility
 * เพื่อไม่ให้ recursion ซ้อนกลับไปเช็ก mustPair/EMP อีก
 ***********************/
function CORE_checkCandidateShallow_(slot, dept, ctx) {
  const { data, timeline, rules } = ctx;

  const d = CORE_norm_(dept);
  const t = timeline[slot.tIndex];

  const inThisShift = t.cols.map(c => CORE_norm_(data[t.r][c])).filter(Boolean);
  if (inThisShift.indexOf(d) >= 0) return { ok:false, reason:"duplicate dept in same shift" };

  const rule = rules[d];
  if (!rule) return { ok:false, reason:"missing rule" };

  const desire = CORE_getDesire_(rule, t.shift, t.rowType);
  if (desire <= 0) return { ok:false, reason:"desire=0" };

  if (rule.mustNotPair && rule.mustNotPair.length) {
    for (const x of inThisShift) {
      if (x !== "EMP" && rule.mustNotPair.indexOf(x) >= 0) {
        return { ok:false, reason:"hit must_not_pair " + x };
      }
    }
  }

  const cons = CORE_checkNoMoreThan2Consecutive_(timeline, data, slot.tIndex, d, slot.tIndex);
  if (!cons.ok) return { ok:false, reason: cons.reason };

  return { ok:true, reason:"ok" };
}

/***********************
 * SCORE
 ***********************/
function CORE_scoreCandidate_(slot, dept, ctx) {
  const { data, timeline, rules, remaining, scoringPolicy, CFG, colMap } = ctx;

  const d = CORE_norm_(dept);
  const t = timeline[slot.tIndex];
  const rule = rules[d];

  const desire = CORE_getDesire_(rule, t.shift, t.rowType);

  let score = desire * CFG.W_DESIRE;
  let parts = [`desire=${desire}`];

  const hasME = (scoringPolicy.indexOf("ME") >= 0);
  const hasQUOTA = (scoringPolicy.indexOf("QUOTA") >= 0);
  const hasPRIORITY = (scoringPolicy.indexOf("PRIORITY") >= 0);

  if (hasME && (t.shift === "M" || t.shift === "E")) {
    const meVal = (t.rowType === "WEEKDAY") ? Number(rule.meWeekday || 0) : Number(rule.meWeekend || 0);
    const mePotential = CORE_mePotential_(data, t.r, d, colMap);
    if (meVal > 0 && mePotential) {
      const meBonus = meVal * CFG.W_ME_BONUS;
      score += meBonus;
      parts.push(`ME=${meVal}*${CFG.W_ME_BONUS}`);
    }
  }

  if (hasQUOTA) {
    const fix   = Number(rule.fixShift || 0);
    const baseQ = fix > 0 ? fix : Number(rule.ideal || 0);

    const quotaBase = Math.max(1, baseQ);
    const rem = Math.max(0, Number(remaining[d] || 0));

    const quotaBonus = (rem / quotaBase) * CFG.W_QUOTA;
    score += quotaBonus;
    parts.push(`quota=${rem}/${quotaBase}*${CFG.W_QUOTA}`);
  }

  if (hasPRIORITY) {
    const p = Math.max(0, Math.min(10, Number(rule.priority || 0)));
    const prBonus = p * CFG.W_PRIORITY;
    score += prBonus;
    parts.push(`priority=${p}*${CFG.W_PRIORITY}`);
  }

  return { score, reason: parts.join(", ") };
}

/***********************
 * UTIL: collect empty slots
 ***********************/
function CORE_collectEmptySlots_(timeline, acceptTypeFn, data, colMap) {
  const slots = [];
  for (let i = 0; i < timeline.length; i++) {
    const t = timeline[i];
    if (!acceptTypeFn(t.rowType)) continue;

    for (const c of t.cols) {
      if (!CORE_norm_(data[t.r][c])) {
        slots.push({
          r: t.r,
          c,
          shift: t.shift,
          day: data[t.r][colMap.dayCol],
          tIndex: i
        });
      }
    }
  }
  return slots;
}

/***********************
 * SLOT maker
 ***********************/
function CORE_makeSlot_(r, shift, c, tIndexMap, data, colMap) {
  const key = r + "|" + shift;
  const tIndex = (tIndexMap && tIndexMap[key] != null) ? tIndexMap[key] : -1;
  const day = data[r][colMap.dayCol];
  return { r, c, shift, day, tIndex };
}

/***********************
 * Partner col picker
 ***********************/
function CORE_pickEmptyPartnerCol_(t, placedCol, data) {
  for (const c of t.cols) {
    if (c === placedCol) continue;
    if (!CORE_norm_(data[t.r][c])) return c;
  }
  return null;
}

/***********************
 * Partner picker
 ***********************/
function CORE_pickBestPartnerForSlot_(slot2, mustPairList, ctx) {
  const { deptList, remaining } = ctx;

  const cands = (mustPairList || [])
    .map(CORE_norm_)
    .filter(Boolean)
    .filter(p => deptList.indexOf(p) >= 0)
    .filter(p => (remaining[p] || 0) > 0)
    .map(p => {
      const check = CORE_checkCandidate_(slot2, p, ctx);
      if (!check.ok) return null;
      const scoreObj = CORE_scoreCandidate_(slot2, p, ctx);
      return { dept:p, score: scoreObj.score, reason: scoreObj.reason };
    })
    .filter(Boolean)
    .sort((x,y) => y.score - x.score);

  return cands.length ? cands[0] : null;
}

/***********************
 * EMP/mustPair feasibility
 * ใช้ shallow check เพื่อกัน recursion ซ้อน
 ***********************/
function CORE_hasFeasiblePartnerForEmpMulti_(slot, dept, ctx) {
  const { data, timeline, deptList, rules, remaining, tIndexMap, colMap } = ctx;

  const d = CORE_norm_(dept);
  const t = timeline[slot.tIndex];
  const rule = rules[d];
  if (!rule) return false;

  const mp = (rule.mustPair && rule.mustPair.length) ? rule.mustPair : [];
  if (!mp.length) return false;

  const emptyPartnerCols = t.cols.filter(c => c !== slot.c && !CORE_norm_(data[t.r][c]));
  if (!emptyPartnerCols.length) return false;

  const inShift = t.cols.map(c => CORE_norm_(data[t.r][c])).filter(Boolean);
  if (inShift.length > 0) return true;

  for (const partnerCol of emptyPartnerCols) {
    const slot2 = CORE_makeSlot_(t.r, t.shift, partnerCol, tIndexMap, data, colMap);

    for (const p0 of mp) {
      const p = CORE_norm_(p0);
      if (!p) continue;
      if (deptList.indexOf(p) < 0) continue;
      if ((remaining[p] || 0) <= 0) continue;

      const check = CORE_checkCandidateShallow_(slot2, p, ctx);
      if (check.ok) return true;
    }
  }

  return false;
}

/***********************
 * PLACE
